{
    "kind": "collectionType",
    "collectionName": "proyectos",
    "info": {
        "singularName": "proyecto",
        "pluralName": "proyectos",
        "displayName": "Proyecto",
        "description": "Proyectos realizados por Voltura Projects"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "titulo": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "titulo",
            "required": true
        },
        "descripcionCorta": {
            "type": "text",
            "required": true,
            "maxLength": 200
        },
        "descripcionCompleta": {
            "type": "richtext",
            "required": true
        },
        "imagenPrincipal": {
            "type": "media",
            "multiple": false,
            "required": true,
            "allowedTypes": [
                "images"
            ]
        },
        "galeria": {
            "type": "media",
            "multiple": true,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "ubicacion": {
            "type": "string",
            "required": false
        },
        "fechaRealizacion": {
            "type": "date",
            "required": false
        },
        "duracion": {
            "type": "string",
            "required": false
        },
        "superficie": {
            "type": "string",
            "required": false
        },
        "presupuesto": {
            "type": "string",
            "required": false
        },
        "cliente": {
            "type": "string",
            "required": false
        },
        "destacado": {
            "type": "boolean",
            "default": false
        },
        "orden": {
            "type": "integer",
            "default": 0
        },
        "tags": {
            "type": "json",
            "required": false
        },
        "servicios": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::servicio.servicio",
            "inversedBy": "proyectos"
        },
        "caracteristicasTecnicas": {
            "type": "component",
            "repeatable": true,
            "component": "proyecto.caracteristica-tecnica"
        },
        "metaTitle": {
            "type": "string",
            "required": false
        },
        "metaDescription": {
            "type": "text",
            "required": false,
            "maxLength": 160
        }
    }
}